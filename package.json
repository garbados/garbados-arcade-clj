{
  "private": true,
  "scripts": {
    "start": "shadow-cljs server",
    "build": "npm run build:html && npm run build:games",
    "build:html": "lein exec -p scripts/build_html.clj",
    "build:games": "shadow-cljs compile ambition",
    "release": "npm run build",
    "dev": "npm run build:html && shadow-cljs watch",
    "test": "lein test",
    "test:ambition": "lein test :ambition",
    "cov": "lein cloverage",
    "cov:ambition": "lein cloverage --selector :ambition"
  },
  "devDependencies": {
    "shadow-cljs": "^3.4.11"
  },
  "dependencies": {
    "@pixi/ui": "^2.2.1",
    "pixi.js": "^8.19.0"
  }
}
